# Copy to .env and fill in. Never commit .env.

# Needs Scribe + TTS; for /clone-voice also enable create_instant_voice_clone on the key in ElevenLabs.
ELEVENLABS_API_KEY=
# Optional override — default https://api.elevenlabs.io/v1/voices/add
# ELEVENLABS_CLONE_URL=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Optional — Gemini text model (default: gemini-3.1-flash-lite-preview). Use gemini-3-flash-preview if 404.
# GEMINI_CHAT_MODEL=

# Convex — REQUIRED for saving sessions from POST /process (same URL as frontend VITE_CONVEX_URL)
# Production example: https://groovy-corgi-683.eu-west-1.convex.cloud
CONVEX_URL=

# Optional — only if Convex returns 401 on /api/mutation without it (Settings → Deploy key)
# CONVEX_DEPLOY_KEY=

# FRONTEND_URL=

# Optional — same Telegram app as SpeechBuddy MTProto listener (see ../telegram-mtproto-voice/)
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=

# POST /process — optional form field `voice_id` overrides Convex profile (e.g. Telegram clone from telegram_users)

# Optional — Bot API token from @BotFather (e.g. @speechbridgebot); not the same as MTProto user login
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=speechbridgebot
