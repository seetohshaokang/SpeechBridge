# SpeechBuddy: get api_id + api_hash from https://my.telegram.org/apps → App configuration
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# User account login (MTProto user API — not the Bot API token)
# International format with +, e.g. +6591234567
TELEGRAM_PHONE=

# Session file basename (creates ./speechbuddy.session)
TELEGRAM_SESSION_NAME=speechbuddy

# Comma-separated chat IDs you have written consent to process.
# Private DMs: the *peer* user id (the other person). You can list both parties’ ids.
# Groups/supergroups: negative id, e.g. -1001234567890
# Example: 8246502160
ALLOWED_CHAT_IDS=

# Where to save downloaded voice notes before reconstruction / ASR
VOICE_DOWNLOAD_DIR=downloads/voice

# SpeechBridge backend — voice notes POSTed to /process for STT → correction → TTS
SPEECHBRIDGE_API_URL=http://localhost:8001
# dysarthria | stuttering | aphasia | general
SPEECH_CONDITION=general

# Convex — same deployment URL as backend/ and frontend VITE_CONVEX_URL (stores telegram_users.voice_id)
# Example: https://your-deployment.convex.cloud
CONVEX_URL=
# Optional — if Convex HTTP returns 401 without it (Settings → Deploy key)
# CONVEX_DEPLOY_KEY=

# Minimum voice-note length (seconds) to accept as a clone sample when voice_id is missing
# TELEGRAM_MIN_CLONE_SECONDS=30

# Bot API — required for bot_listener.py / start_services.sh (@BotFather)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=speechbridgebot
