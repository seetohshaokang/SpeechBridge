# FastAPI backend (e.g. `deploy-local.sh` uses port 8000)
VITE_API_URL=http://localhost:8000

# From Convex (after `npx convex dev` — usually in .env.local already)
VITE_CONVEX_URL=

# Clerk → API keys → Publishable key (Vite: VITE_*, not NEXT_PUBLIC_*)
VITE_CLERK_PUBLISHABLE_KEY=

# Optional: Clerk secret key — server-side only; do not prefix with VITE_
# CLERK_SECRET_KEY=

# Convex backend (not Vite): set with CLI so auth.config.ts can validate JWTs
# Same value as Clerk "Frontend API URL" / Issuer (e.g. https://xxx.clerk.accounts.dev)
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN "https://xxx.clerk.accounts.dev"
