# FastAPI backend (e.g. `deploy-local.sh` uses port 8000)
API_URL=http://localhost:8000

# Convex (client) — exposed via vite.config.js envPrefix CONVEX_
CONVEX_URL=
# Optional: .convex.site (HTTP actions / site features)
CONVEX_SITE_URL=

# Clerk publishable key (exposed via envPrefix CLERK_PUBLISHABLE_ in vite.config.js)
CLERK_PUBLISHABLE_KEY=

# Optional: Clerk secret key — server-side only; never expose to the browser
# CLERK_SECRET_KEY=

# Convex backend (not the Vite app): set with CLI so auth.config.ts can validate JWTs
# Same value as Clerk "Frontend API URL" / Issuer (e.g. https://xxx.clerk.accounts.dev)
#   (from repo root) npx convex env set CLERK_JWT_ISSUER_DOMAIN "https://xxx.clerk.accounts.dev"
