# Copy to .env.local — only VITE_* vars are available in the browser (vite.config envPrefix).

# FastAPI backend (default dev port 8001)
VITE_API_URL=http://localhost:8001

# Convex HTTP/WebSocket URL (Convex dashboard → Settings)
VITE_CONVEX_URL=
# Optional: .convex.site (HTTP actions / site features)
VITE_CONVEX_SITE_URL=

# Clerk publishable key (Clerk → API keys)
VITE_CLERK_PUBLISHABLE_KEY=

# Optional: Clerk secret — never prefix with VITE_ (must not ship to the client)
# CLERK_SECRET_KEY=

# Optional: for Convex CLI when running from frontend dir (see repo root .env.local)
# CONVEX_DEPLOYMENT=

# Convex backend (not Vite): from repo root, e.g.
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN "https://xxx.clerk.accounts.dev"
